# CompassDocs self-hosting configuration (used by deploy/docker-compose.yml).
# The install script generates strong random values for you; if you write this
# by hand, replace the passwords with your own secrets.

# Database password (any strong random string).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Initial admin account created on first launch. Sign in with these, then
# manage users from the Admin page.
COMPASSDOCS_ADMIN_USER=admin
COMPASSDOCS_ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: enable AI-powered "Ask CompassDocs" answers. Search works without it.
# ANTHROPIC_API_KEY=sk-ant-...

# Port to expose the app on (http://localhost:PORT).
PORT=3000

# Optional: pin a specific released version instead of the latest image.
# COMPASSDOCS_VERSION=1.0.0
