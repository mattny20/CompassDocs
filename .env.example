# CompassDocs configuration

# --- Database (required) ------------------------------------------------------
# Postgres connection string. Works with any Postgres — Neon, Supabase, Railway,
# Render, Fly, or a local instance. Managed hosts give you this value directly.
DATABASE_URL=postgres://user:password@host:5432/compassdocs

# SSL is enabled automatically for remote hosts and disabled for localhost.
# Override if needed: set to "disable" to force it off (e.g. some local setups).
# DATABASE_SSL=disable
# Max pool connections per instance (default 5). Lower it on serverless hosts.
# DATABASE_POOL_MAX=5

# --- Authentication -----------------------------------------------------------
# On first run, CompassDocs creates a single admin account. By default that's
# username "admin" / password "admin", and you're forced to change the password
# at first login. Override the bootstrap credentials here:
# COMPASSDOCS_ADMIN_USER=admin
# COMPASSDOCS_ADMIN_PASSWORD=change-me-now
# (If COMPASSDOCS_ADMIN_PASSWORD is set, the forced first-login change is skipped.)

# --- AI search ----------------------------------------------------------------
# Optional: enables AI-powered "Ask CompassDocs" answers over your knowledge base.
# Without a key, search still works fully via Postgres full-text search — the app
# falls back to ranked document snippets instead of a synthesized answer.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for AI answers (default: claude-opus-4-8).
# COMPASSDOCS_AI_MODEL=claude-opus-4-8
